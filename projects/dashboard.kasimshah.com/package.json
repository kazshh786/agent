{
  "name": "ks-unified-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready multi-tenant agency dashboard with Supabase auth, workspace isolation, and Vercel serverless API.",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npx vercel dev",
    "build": "node scripts/build.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose --forceExit",
    "verify": "node scripts/verify.js",
    "test:auth": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/auth.test.js --verbose",
    "test:membership": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/membership.test.js --verbose",
    "test:roles": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/roles.test.js --verbose",
    "test:validation": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/validation.test.js --verbose",
    "test:api": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/api-routes.test.js --verbose",
    "test:workspace": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/workspace-switching.test.js --verbose",
    "test:engine": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/website-engine.test.js --verbose",
    "test:xss": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/xss.test.js --verbose",
    "test:methods": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/http-methods.test.js --verbose"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverage": false,
    "verbose": true
  }
}
