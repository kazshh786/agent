# Environment Variables for KS Unified Dashboard
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real credentials.

# Supabase project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase anonymous/public key (safe for browser)
SUPABASE_ANON_KEY=

# Supabase service role key (server-side ONLY — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# External website engine API base URL (e.g. https://engine.example.com)
WEBSITE_ENGINE_API_URL=

# Authentication token for the website engine API (server-side ONLY)
WEBSITE_ENGINE_API_TOKEN=

# Public application URL (used for CORS, redirects, CSP)
# Local: http://localhost:3000
# Production: https://dashboard.kasimshah.com
APP_URL=

# 32 random bytes encoded as base64. Used only server-side for AES-256-GCM.
INTEGRATION_ENCRYPTION_KEY=
# Bearer secret used by the external scheduler calling POST /api/jobs/run.
JOB_RUNNER_SECRET=
# KS OS will be enabled after it exposes a service-token integration contract.
KS_OS_API_URL=
KS_OS_SERVICE_TOKEN=
BOOKING_RATE_LIMIT_SALT=
# Shared 32+ character HMAC secret used by KS OS and this dashboard.
AUTOMATION_EVENT_SECRET=
# Worker bearer token. Vercel CRON_SECRET may be used instead.
AUTOMATION_WORKER_SECRET=
CRON_SECRET=

# Dedicated 32+ character HMAC secret. Never reuse the automation secret.
ATTRIBUTION_IDENTITY_SECRET=
# Set true only after verifying headers on the deployed environment.
SECURITY_HEADERS_ACTIVE=false
# Production and staging must remain false.
ALLOW_MOCK_FALLBACKS=false

# Phase 10 release gate. Use different values for staging and production.
APP_ENV=
STAGING_DASHBOARD_URL=
STAGING_KS_OS_URL=
STAGING_WORKSPACE_ID=
# Short-lived platform owner/admin Supabase access token for manual smoke only.
STAGING_PLATFORM_ACCESS_TOKEN=
